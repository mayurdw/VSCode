{
    // Normal VSCode Settings
    "workbench.colorTheme": "Experimental Dark",
    "editor.renderWhitespace": "all",
    "editor.fontFamily": "Cascadia Mono",
    "editor.fontSize": 16,
    "editor.fontLigatures": true,
    "editor.formatOnSave": true,
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    "editor.stickyScroll.enabled": false,
    "workbench.activityBar.location": "hidden",
    // VIM Settings
    "vim.inccommand": "replace",
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ],
            "commands": [
                ":w!"
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        // NAVIGATION
        {
            "before": [
                "[",
                "b"
            ],
            "commands": [
                ":bprevious"
            ]
        },
        {
            "before": [
                "]",
                "b"
            ],
            "commands": [
                ":bnext"
            ]
        },
        {
            "before": [
                "S-q>"
            ],
            "commands": [
                ":bquit"
            ]
        },
        // splits
        {
            "before": [
                "leader",
                "w",
                "v"
            ],
            "commands": [
                ":vsplit"
            ]
        },
        {
            "before": [
                "leader",
                "w",
                "h"
            ],
            "commands": [
                ":split"
            ]
        },
        // panes
        {
            "before": [
                "<M-h>",
            ],
            "commands": [
                "workbench.action.focusLeftGroup"
            ]
        },
        {
            "before": [
                "<M-j>"
            ],
            "commands": [
                "workbench.action.focusBelowGroup"
            ]
        },
        {
            "before": [
                "<M-k>"
            ],
            "commands": [
                "workbench.action.focusAboveGroup"
            ]
        },
        {
            "before": [
                "<M-l>"
            ],
            "commands": [
                "workbench.action.focusRightGroup"
            ]
        },
        // LSP
        // Go to Definition
        {
            "before": [
                "g",
                "d"
            ],
            "commands": [
                "editor.action.goToDefinition"
            ]
        },
        // Show Hover
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showDefinitionPreviewHover"
            ]
        },
        // Go to Implementations
        {
            "before": [
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ]
        },
        // Quick fix
        {
            "before": [
                "leader",
                "a",
                "m"
            ],
            "commands": [
                "editor.action.quickFix"
            ]
        },
        // Go to References
        {
            "before": [
                "leader",
                "g",
                "u"
            ],
            "commands": [
                "editor.action.referenceSearch.trigger"
            ]
        },
        // Go to Type Definition
        {
            "before": [
                "g",
                "t"
            ],
            "commands": [
                "editor.action.goToTypeDefinition"
            ]
        },
        // Peek Type Definition
        {
            "before": [
                "g",
                "p",
                "t"
            ],
            "commands": [
                "editor.action.peekTypeDefinition"
            ]
        },
        // NICE TO HAVE
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<Esc>"
            ],
            "commands": [
                ":w!"
            ]
        },
        {
            "before": [
                "leader",
                "q",
                "o"
            ],
            "commands": [
                ":wall"
            ]
        },
        {
            "before": [
                "leader",
                "q",
                "c"
            ],
            "commands": [
                ":q!"
            ]
        },
        {
            "before": [
                "leader",
                "Q"
            ],
            "commands": [
                ":qall"
            ]
        },
        {
            "before": [
                "[",
                "d"
            ],
            "commands": [
                "editor.action.marker.prev"
            ]
        },
        {
            "before": [
                "]",
                "d"
            ],
            "commands": [
                "editor.action.marker.next"
            ]
        },
        {
            "before": [
                "m",
                "t"
            ],
            "commands": [
                "editor.action.jumpToBracket"
            ]
        },
        {
            "before": [
                "leader",
                "f",
                "f"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "leader",
                "p"
            ],
            "commands": [
                "editor.action.formatDocument"
            ]
        },
        {
            // VSCodeVim can "prepare" replace but forces the manual mode exit
            // to perform replacement leader => O => esc
            // extension.vim_escape performs that mode change
            // "before": ["<leader>", "O"],
            // "commands": ["type", ":%s/1test1/gold/g", "extension.vim_escape"]
            // 1test1
        },
        {
            "before": [
                "<space>",
                "s"
            ],
            "after": [
                "*",
                ":",
                "%",
                "s",
                "/",
                "/"
            ]
        },
        // Clear the search highlight
        {
            "before": [
                "<leader>",
                "/"
            ],
            "commands": [
                ":noh"
            ]
        }
        // Runs task defined in .../User/.vscode/task.json
        // {
        // 	"before": ["<leader>", "r", "t"],
        // 	"commands": [
        // 		{
        // 			"command": "workbench.action.tasks.runTask",
        // 			"args": "echo"
        // 		}
        // 	]
        // }
    ],
    "vim.visualModeKeyBindings": [
        // Stay in visual mode while indenting
        {
            "before": [
                "<"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        },
        {
            "before": [
                ">"
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        // Move selected lines while staying in visual mode
        {
            "before": [
                "J"
            ],
            "commands": [
                "editor.action.moveLinesDownAction"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.moveLinesUpAction"
            ]
        },
        // toggle comment selection
        {
            "before": [
                "leader",
                "c"
            ],
            "commands": [
                "editor.action.commentLine"
            ]
        },
        {
            "before": [
                "leader",
                "C"
            ],
            "commands": [
                "editor.action.blockComment"
            ]
        },
        {
            "before": [
                "leader",
                "shift",
                "/"
            ],
            "commands": [
                "editor.action.blockComment"
            ]
        },
        {
            "before": [
                "<Space>",
                "s"
            ],
            "after": [
                ":",
                "s",
                "/"
            ]
        }
    ],
    "vim.leader": " ",
    "vim.hlsearch": true,
    "vim.smartRelativeLine": true,
    "vim.autoindent": true,
    "vim.useSystemClipboard": true,
    "vim.highlightedyank.enable": true,
}